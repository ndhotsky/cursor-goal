{
  "name": "cursor-goal",
  "version": "0.3.2",
  "description": "Codex-style /goal loops for Cursor Agent chat with durable local state.",
  "type": "module",
  "license": "MIT",
  "author": "Niko",
  "homepage": "https://github.com/ndhotsky/cursor-goal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ndhotsky/cursor-goal.git"
  },
  "bugs": {
    "url": "https://github.com/ndhotsky/cursor-goal/issues"
  },
  "keywords": [
    "cursor",
    "composer-2.5",
    "codex",
    "goal",
    "agent",
    "ai-coding",
    "typescript"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "cursor-goal": "./dist/index.js",
    "cgoal": "./dist/index.js",
    "cursor-goal-install-skill": "./scripts/install-skill.sh",
    "cursor-goal-install-hook": "./scripts/install-hook.sh"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".cursor/skills/goal/SKILL.md",
    "scripts/install-skill.sh",
    "scripts/evaluate-goal.sh",
    "scripts/install-hook.sh",
    "docs",
    "examples"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/*.test.ts && bash test/install-skill.test.sh && bash test/install-hook.test.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "parity": "tsx scripts/parity-harness.ts",
    "install-skill": "bash scripts/install-skill.sh",
    "install-skill:global": "bash scripts/install-skill.sh --global",
    "install-hook": "bash scripts/install-hook.sh",
    "install-hook:global": "bash scripts/install-hook.sh --global",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
