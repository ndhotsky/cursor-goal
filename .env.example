# Optional default model id recorded in goal state (audit only).
# Install: docs/install.md
CURSOR_GOAL_MODEL=composer-2.5

# Optional legacy mode: store state in <workspace>/.goal instead of the user state directory.
# CURSOR_GOAL_STATE_SCOPE=workspace

# Optional explicit state root for all cursor-goal workspaces.
# CURSOR_GOAL_STATE_DIR=/path/to/cursor-goal-state
